@import "tailwindcss";

:root {
  --background: #f3f4f6;
  --foreground: #111827;
  --muted: #7b8798;
  --muted-strong: #445066;
  --brand-900: #2563eb;
  --brand-700: #3b82f6;
  --brand-500: #bfdbfe;
  --surface: #ffffff;
  --surface-subtle: #f8f9fb;
  --surface-elevated: #f5f6f8;
  --border: #e3ebf5;
  --border-subtle: #f2f6fb;
  --ring: #93c5fd;
  --sidebar-bg: rgba(255, 255, 255, 0.9);
  --topbar-bg: #ffffff;
  --hover-bg: #eff6ff;
  --nav-active-bg: #dbeafe;
  --nav-active-border: #bfdbfe;
  --nav-active-color: #1d4ed8;
  --chip-bg: #ffffff;
  --placeholder: #9aa8ba;
  --table-row-hover: #f7f8fa;
  --analytics-bar: #e5e7eb;
  --activity-bg: #fcfcfd;
  --success-bg: #e4f8e9;
  --success-text: #1f9a51;
  --shadow-sm: 0 8px 20px rgba(148, 163, 184, 0.12);
  --shadow-md: 0 18px 42px rgba(148, 163, 184, 0.18);
  --interaction-duration: 140ms;
  --interaction-ease: ease-out;
  --sidebar-width: 228px;
  --topbar-height: 76px;
}

:root[data-theme="dark"] {
  --background: #05060a;
  --foreground: #eef2f7;
  --muted: #8d97a8;
  --muted-strong: #d7dde7;
  --brand-900: #60a5fa;
  --brand-700: #3b82f6;
  --brand-500: #bfdbfe;
  --surface: #080a0f;
  --surface-subtle: #0d1016;
  --surface-elevated: #0a0d13;
  --border: #151c25;
  --border-subtle: #10161d;
  --ring: #60a5fa;
  --sidebar-bg: #06080c;
  --topbar-bg: #06080c;
  --hover-bg: #0f1b2d;
  --nav-active-bg: #10233f;
  --nav-active-border: #1f4f8f;
  --nav-active-color: #dbeafe;
  --chip-bg: #0d1218;
  --placeholder: #7d8798;
  --table-row-hover: #0e131a;
  --analytics-bar: #171f28;
  --activity-bg: #0c1016;
  --success-bg: #0d2416;
  --success-text: #86efac;
  --shadow-sm: 0 6px 16px rgba(0, 0, 0, 0.44);
  --shadow-md: 0 22px 52px rgba(0, 0, 0, 0.62);
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-nunito);
  --font-mono: var(--font-geist-mono);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-nunito), "Segoe UI", Arial, sans-serif;
  overflow-x: hidden;
  transition: background-color 200ms ease-in-out, color 200ms ease-in-out;
}

body {
  background-image: linear-gradient(180deg, #f7f7f8 0%, var(--background) 100%);
}

:root[data-theme="dark"] body {
  background:
    radial-gradient(circle at 18% -12%, rgba(59, 130, 246, 0.1) 0%, rgba(59, 130, 246, 0) 38%),
    radial-gradient(circle at 100% 0%, rgba(96, 165, 250, 0.08) 0%, rgba(96, 165, 250, 0) 34%),
    #05060a;
}

a {
  color: inherit;
  text-decoration: none;
}

.app-bg {
  min-height: 100vh;
  background: transparent;
}

.app-shell {
  min-height: 100vh;
}

.app-sidebar {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: var(--sidebar-width);
  background: var(--sidebar-bg);
  border: none;
  border-right: 1px solid var(--border);
  border-radius: 0;
  padding: 20px 14px;
  z-index: 40;
  backdrop-filter: none;
  box-shadow: none;
  transition: transform 220ms ease-in-out;
}

.logo-box {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--foreground);
  letter-spacing: 0.01em;
  margin-bottom: 24px;
  padding: 4px 6px 12px;
}

.logo-mark {
  width: 36px;
  height: 36px;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--brand-900), var(--brand-700));
  color: #fff;
  display: grid;
  place-items: center;
  box-shadow: 0 10px 18px rgba(37, 99, 235, 0.22);
}

.logo-copy {
  display: grid;
  gap: 2px;
}

.logo-copy span {
  font-size: 19px;
  font-weight: 700;
}

.logo-copy small {
  font-size: 11px;
  color: var(--muted);
  font-weight: 600;
}

.side-nav {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.side-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 11px 14px;
  border-radius: 14px;
  border: 1px solid transparent;
  color: var(--muted-strong);
  font-size: 13px;
  font-weight: 600;
  transition:
    background-color var(--interaction-duration) var(--interaction-ease),
    border-color var(--interaction-duration) var(--interaction-ease),
    color var(--interaction-duration) var(--interaction-ease);
}

.side-link:hover {
  background: var(--hover-bg);
  border-color: var(--border-subtle);
  color: var(--foreground);
}

.side-link svg {
  color: var(--muted);
  transition: color var(--interaction-duration) var(--interaction-ease);
}

.side-link:hover svg,
.side-link.active svg {
  color: currentColor;
}

.side-link.active {
  background: var(--nav-active-bg);
  border-color: var(--nav-active-border);
  color: var(--nav-active-color);
  font-weight: 700;
  box-shadow: none;
}

.app-main {
  margin-left: var(--sidebar-width);
  min-width: 0;
  min-height: 100vh;
  padding: calc(var(--topbar-height) + 16px) 24px 24px;
}

.app-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  position: fixed;
  top: 0;
  left: var(--sidebar-width);
  right: 0;
  height: var(--topbar-height);
  z-index: 35;
  background: var(--topbar-bg);
  border: none;
  border-bottom: 1px solid var(--border);
  border-radius: 0;
  padding: 10px 18px;
  box-shadow: none;
  margin-bottom: 0;
  backdrop-filter: none;
}

.topbar-left {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  flex: 1;
}

.top-breadcrumbs {
  display: flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
  overflow: hidden;
}

.top-breadcrumb-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
}

.top-breadcrumb-separator {
  color: var(--muted);
  flex: 0 0 auto;
}

.top-breadcrumb-link,
.top-breadcrumb-current {
  display: inline-block;
  max-width: 220px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 14px;
  line-height: 1.2;
}

.top-breadcrumb-link {
  color: var(--muted);
  text-decoration: none;
  transition: color 180ms ease-in-out;
}

.top-breadcrumb-link:hover {
  color: var(--foreground);
}

.top-breadcrumb-current {
  color: var(--foreground);
  font-weight: 700;
}

.topbar-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.mobile-menu-btn {
  display: none;
}

.top-fact-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 320px;
  max-width: 620px;
  width: 100%;
  min-height: 40px;
  border: 1px solid #eef3fb;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.88);
  padding: 8px 12px;
}

.top-fact-icon {
  width: 28px;
  height: 28px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--surface-subtle);
  color: var(--brand-900);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
}

.top-fact-copy {
  display: grid;
  gap: 1px;
  min-width: 0;
  flex: 1;
}

.top-fact-label {
  font-size: 10px;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.top-fact-text {
  font-size: 13px;
  color: var(--muted-strong);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.avatar-chip {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 4px 10px 4px 4px;
  border: 1px solid rgba(255, 255, 255, 0.78);
  border-radius: 999px;
  background: var(--chip-bg);
  box-shadow: var(--shadow-sm);
}

.avatar-dot {
  width: 30px;
  height: 30px;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--brand-900), var(--brand-700));
  color: #fff;
  display: grid;
  place-items: center;
  font-size: 12px;
  font-weight: 700;
}

.avatar-copy {
  display: grid;
  gap: 1px;
}

.avatar-text {
  font-size: 12px;
  font-weight: 700;
  color: var(--muted-strong);
  line-height: 1.1;
}

.avatar-subtext {
  font-size: 10px;
  color: var(--muted);
  line-height: 1.1;
}

.top-icon-btn {
  width: 40px;
  height: 40px;
  border-radius: 14px;
  border: 1px solid #e8eff9;
  background: rgba(255, 255, 255, 0.9);
  color: var(--muted-strong);
  display: inline-grid;
  place-items: center;
  cursor: pointer;
  position: relative;
  transition: border-color 180ms ease-in-out, background-color 180ms ease-in-out, color 180ms ease-in-out;
}

.top-icon-btn:hover {
  border-color: var(--ring);
  background: #f8fbff;
}

.top-notify-btn svg {
  width: 16px;
  height: 16px;
}

.notify-badge {
  position: absolute;
  top: -3px;
  right: -2px;
  min-width: 16px;
  height: 16px;
  border-radius: 999px;
  background: var(--brand-900);
  color: #fff;
  display: inline-grid;
  place-items: center;
  font-size: 9px;
  font-weight: 700;
  line-height: 1;
  border: 2px solid #fff;
}

.app-content {
  min-width: 0;
}

.app-content > div {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
  box-shadow: none;
}

.greet-title {
  font-size: 24px;
  font-weight: 700;
  line-height: 1.2;
}

.greet-subtitle {
  color: var(--muted);
  margin-top: 2px;
  font-size: 14px;
}

.summary-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
}

.metric-strip {
  border: 1px solid rgba(255, 255, 255, 0.78);
  border-radius: 24px;
  background: var(--surface);
  box-shadow: var(--shadow-sm);
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  overflow: hidden;
}

.metric-item {
  padding: 20px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  border-right: 1px solid var(--border-subtle);
}

.metric-item:last-child {
  border-right: none;
}

.metric-head {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--muted);
  font-size: 13px;
  font-weight: 600;
}

.metric-icon {
  width: 16px;
  height: 16px;
  border-radius: 999px;
}

.metric-value {
  display: flex;
  align-items: center;
  gap: 8px;
}

.metric-value strong {
  font-size: 34px;
  line-height: 1;
  letter-spacing: -0.02em;
}

.trend-chip {
  border-radius: 999px;
  padding: 2px 8px;
  font-size: 11px;
  font-weight: 600;
  background: var(--success-bg);
  color: var(--success-text);
}

.floating-toast {
  position: fixed;
  top: 24px;
  right: 24px;
  z-index: 80;
  min-width: min(320px, calc(100vw - 32px));
  max-width: min(420px, calc(100vw - 32px));
  padding: 12px 16px;
  border-radius: 14px;
  border: 1px solid var(--success-bg);
  box-shadow: 0 14px 30px rgba(15, 23, 42, 0.16);
  backdrop-filter: blur(10px);
  animation: toast-slide-in 180ms ease-out;
}

.floating-toast-success {
  background: var(--success-bg);
  color: var(--success-text);
}

@keyframes toast-slide-in {
  from {
    opacity: 0;
    transform: translate3d(0, -10px, 0);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@media (max-width: 640px) {
  .floating-toast {
    top: 16px;
    right: 16px;
    left: 16px;
    min-width: 0;
    max-width: none;
  }
}

.dashboard-row {
  display: grid;
  gap: 18px;
  grid-template-columns: 2fr 1fr;
  align-items: start;
}

.analytics-bars {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 8px;
  align-items: end;
  margin-top: 14px;
}

.analytics-bar {
  border-radius: 10px 10px 6px 6px;
  background: var(--analytics-bar);
  transition: background-color var(--interaction-duration) var(--interaction-ease);
}

.analytics-bar.active {
  background: linear-gradient(180deg, var(--brand-700) 0%, var(--brand-900) 100%);
}

.promo-card {
  border-radius: 16px;
  color: #fff;
  padding: 20px;
  background:
    radial-gradient(circle at 75% 110%, #93c5fd 0%, rgba(147, 197, 253, 0.28) 30%, transparent 35%),
    radial-gradient(circle at 90% 105%, #60a5fa 0%, rgba(96, 165, 250, 0.28) 30%, transparent 35%),
    linear-gradient(145deg, #2563eb, #1d4ed8);
  box-shadow: var(--shadow-md);
}

.promo-pill {
  display: inline-block;
  border-radius: 999px;
  padding: 4px 10px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.02em;
  background: rgba(255, 255, 255, 0.2);
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.activity-item {
  border: 1px solid #eef3fb;
  border-radius: 16px;
  padding: 12px;
  background: var(--activity-bg);
}

.activity-feed {
  display: grid;
  gap: 8px;
}

.activity-feed-card {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 16px;
  border: 1px solid #e8eef8;
  background:
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.08), transparent 28%),
    linear-gradient(180deg, #ffffff, #f8fbff);
  box-shadow: 0 8px 18px rgba(148, 163, 184, 0.08);
}

.activity-feed-card.urgent {
  border-color: #fed7aa;
  background:
    radial-gradient(circle at top right, rgba(249, 115, 22, 0.12), transparent 28%),
    linear-gradient(180deg, #fffaf5, #fff7ed);
}

.activity-feed-main {
  display: flex;
  gap: 10px;
  min-width: 0;
  flex: 1;
}

.activity-feed-icon {
  width: 34px;
  height: 34px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
}

.activity-feed-icon.tone-blue {
  background: #dbeafe;
  color: #1d4ed8;
}

.activity-feed-icon.tone-green {
  background: #dcfce7;
  color: #166534;
}

.activity-feed-icon.tone-amber {
  background: #ffedd5;
  color: #c2410c;
}

.activity-feed-icon.tone-red {
  background: #fee2e2;
  color: #b91c1c;
}

.activity-feed-icon.tone-slate {
  background: #e5e7eb;
  color: #374151;
}

.activity-feed-topline {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.activity-feed-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  padding: 3px 8px;
  font-size: 10px;
  font-weight: 700;
}

.activity-feed-chip.tone-blue {
  background: #dbeafe;
  color: #1d4ed8;
}

.activity-feed-chip.tone-green {
  background: #dcfce7;
  color: #166534;
}

.activity-feed-chip.tone-amber {
  background: #ffedd5;
  color: #c2410c;
}

.activity-feed-chip.tone-red {
  background: #fee2e2;
  color: #b91c1c;
}

.activity-feed-chip.tone-slate {
  background: #e5e7eb;
  color: #374151;
}

.activity-feed-time {
  font-size: 10px;
  color: var(--muted);
  font-weight: 600;
}

.activity-feed-title {
  margin-top: 4px;
  font-size: 13px;
  font-weight: 700;
  color: var(--foreground);
}

.activity-feed-message {
  margin-top: 3px;
  font-size: 12px;
  color: var(--muted-strong);
  line-height: 1.45;
}

.activity-feed-meta {
  margin-top: 6px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  font-size: 11px;
  color: var(--muted);
}

.activity-feed-actions {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
  align-items: flex-start;
}

.activity-feed-action-btn {
  padding: 7px 10px;
  border-radius: 12px;
  font-size: 12px;
}

.activity-feed-toggle {
  border: 1px solid var(--border);
  background: #f8fbff;
  color: var(--foreground);
  border-radius: 999px;
  padding: 6px 12px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  transition:
    background-color var(--interaction-duration) var(--interaction-ease),
    border-color var(--interaction-duration) var(--interaction-ease),
    color var(--interaction-duration) var(--interaction-ease);
}

.activity-feed-toggle:hover {
  border-color: var(--ring);
  background: var(--hover-bg);
}

.activity-feed-empty {
  font-size: 13px;
  color: var(--muted);
  padding: 10px 0;
}

.saas-card {
  border: 1px solid rgba(255, 255, 255, 0.82);
  border-radius: 18px;
  background: var(--surface);
  box-shadow: var(--shadow-sm);
  transition:
    border-color var(--interaction-duration) var(--interaction-ease),
    box-shadow var(--interaction-duration) var(--interaction-ease);
}

.saas-card-hover:hover {
  box-shadow: 0 12px 24px rgba(148, 163, 184, 0.14);
}

.panel {
  border: 1px solid rgba(255, 255, 255, 0.82);
  border-radius: 22px;
  background: var(--surface);
  box-shadow: var(--shadow-sm);
}

.btn-primary,
.btn-secondary,
.btn-danger {
  border-radius: 14px;
  padding: 10px 16px;
  font-weight: 600;
  cursor: pointer;
  transition:
    background-color var(--interaction-duration) var(--interaction-ease),
    border-color var(--interaction-duration) var(--interaction-ease),
    color var(--interaction-duration) var(--interaction-ease),
    box-shadow var(--interaction-duration) var(--interaction-ease);
}

.btn-primary {
  border: 1px solid var(--brand-900);
  background: linear-gradient(135deg, var(--brand-900), var(--brand-700));
  color: #fff;
}

.btn-primary:hover {
  border-color: var(--brand-700);
  background: linear-gradient(135deg, #1d4ed8, #3b82f6);
  box-shadow: 0 8px 18px rgba(37, 99, 235, 0.16);
}

.btn-secondary {
  border: 1px solid var(--border);
  background: #f8fbff;
  color: var(--foreground);
}

.btn-secondary:hover {
  border-color: var(--ring);
  background: var(--hover-bg);
  box-shadow: var(--shadow-sm);
}

.btn-danger {
  border: 1px solid #dc2626;
  background: #dc2626;
  color: #fff;
}

.btn-danger:hover {
  background: #b91c1c;
  border-color: #b91c1c;
  box-shadow: 0 8px 18px rgba(220, 38, 38, 0.16);
}

.btn-primary:active,
.btn-secondary:active,
.btn-danger:active {
  box-shadow: none;
}

.asset-action-btn {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  border: 1px solid var(--border);
  background: #f8fbff;
  color: var(--foreground);
  display: inline-grid;
  place-items: center;
  cursor: pointer;
  transition:
    background-color var(--interaction-duration) var(--interaction-ease),
    border-color var(--interaction-duration) var(--interaction-ease),
    color var(--interaction-duration) var(--interaction-ease),
    box-shadow var(--interaction-duration) var(--interaction-ease);
  text-decoration: none;
}

.asset-action-btn:hover {
  border-color: var(--ring);
  background: var(--hover-bg);
  box-shadow: var(--shadow-sm);
}

.asset-action-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.asset-action-btn-primary {
  border-color: var(--brand-900);
  background: linear-gradient(135deg, var(--brand-900), var(--brand-700));
  color: #fff;
}

.asset-action-btn-primary:hover {
  border-color: var(--brand-700);
  background: linear-gradient(135deg, #1d4ed8, #3b82f6);
}

.asset-action-btn-danger {
  border-color: #fecaca;
  background: #fff1f2;
  color: #dc2626;
}

.asset-action-btn-danger:hover {
  border-color: #fca5a5;
  background: #ffe4e6;
