  box-shadow: 0 16px 28px rgba(148, 163, 184, 0.12);
  transition:
    box-shadow var(--interaction-duration) var(--interaction-ease),
    border-color var(--interaction-duration) var(--interaction-ease);
  overflow: hidden;
}

.department-card::after {
  content: "";
  position: absolute;
  inset: auto -10% -48% 38%;
  height: 120px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.5);
  transform: rotate(-8deg);
  pointer-events: none;
}

.department-card:hover {
  box-shadow: 0 14px 24px rgba(148, 163, 184, 0.14);
  border-color: #c9d7ea;
}

.department-card.active {
  border-color: #93c5fd;
  box-shadow: 0 0 0 2px rgba(147, 197, 253, 0.24), 0 22px 38px rgba(148, 163, 184, 0.18);
}

.department-card-label {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  width: fit-content;
  border-radius: 999px;
  padding: 4px 9px;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.03em;
  text-transform: uppercase;
}

.department-card-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
}

.department-card-name {
  font-size: 14px;
  font-weight: 700;
  line-height: 1.35;
  max-width: calc(100% - 52px);
  color: var(--foreground);
}

.department-card-count {
  flex: 0 0 auto;
  min-width: 38px;
  height: 38px;
  border-radius: 14px;
  background: #eff6ff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 800;
  color: #1d4ed8;
}

.reservation-section {
  position: relative;
  display: grid;
  gap: 14px;
  padding: 18px;
  border-radius: 24px;
  border: 1px solid var(--border-subtle);
  overflow: hidden;
  box-shadow: 0 16px 30px rgba(148, 163, 184, 0.12);
}

.reservation-section::before {
  content: none;
  display: none;
}

.reservation-section-reserved {
  background:
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.12), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 250, 255, 0.96));
  border-color: #bfdbfe;
}

.reservation-section-available {
  background:
    radial-gradient(circle at top right, rgba(74, 222, 128, 0.1), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 252, 248, 0.96));
  border-color: #d9e8dc;
}

.reservation-section-drone {
  background:
    radial-gradient(circle at top right, rgba(96, 165, 250, 0.12), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(245, 250, 255, 0.96));
  border-color: #bfdbfe;
}

.reservation-section-reserved::before {
  content: none;
  display: none;
  background: none;
}

.reservation-section-available::before {
  content: none;
  display: none;
  background: none;
}

.reservation-section-drone::before {
  content: none;
  display: none;
  background: none;
}

.reservation-section-head {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  flex-wrap: wrap;
  align-items: flex-start;
}

.reservation-section-titlebar {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.reservation-section-title {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--foreground);
}

.reservation-count-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 30px;
  height: 24px;
  padding: 0 8px;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.12);
  color: #1d4ed8;
  font-size: 12px;
  font-weight: 800;
}

.reservation-count-badge-available {
  background: rgba(22, 163, 74, 0.12);
  color: #166534;
}

.reservation-count-badge-drone {
  background: rgba(96, 165, 250, 0.14);
  color: #1d4ed8;
}

.reservation-section-subtitle {
  margin-top: 2px;
  font-size: 12px;
  color: var(--muted);
  line-height: 1.45;
}

.reservation-list {
  display: grid;
  gap: 8px;
}

.reservation-list-scroll {
  max-height: 336px;
  min-height: 0;
  overflow-x: hidden;
  overflow-y: auto;
  scrollbar-gutter: stable;
  scrollbar-width: thin;
  scrollbar-color: rgba(148, 163, 184, 0.55) transparent;
  padding-right: 4px;
}

.reservation-section-available .reservation-list-scroll {
  max-height: 260px;
  padding-right: 6px;
}

.reservation-section-drone .reservation-list-scroll {
  max-height: 220px;
  padding-right: 6px;
}

.reservation-list-scroll::-webkit-scrollbar {
  width: 10px;
}

.reservation-list-scroll::-webkit-scrollbar-track {
  background: transparent;
}

.reservation-list-scroll::-webkit-scrollbar-thumb {
  border-radius: 999px;
  background: rgba(148, 163, 184, 0.45);
  border: 2px solid transparent;
  background-clip: padding-box;
}

.reservation-list-scroll::-webkit-scrollbar-thumb:hover {
  background: rgba(148, 163, 184, 0.62);
  background-clip: padding-box;
}

.reservation-card {
  position: relative;
  display: grid;
  gap: 10px;
  padding: 14px;
  min-height: 74px;
  border-radius: 16px;
  border: 1px solid var(--border-subtle);
  background: rgba(255, 255, 255, 0.9);
  overflow: visible;
  box-shadow: 0 10px 20px rgba(148, 163, 184, 0.1);
}

.reservation-card::before {
  content: none;
  display: none;
}

.reservation-card-reserved {
  border-color: #bfdbfe;
  background:
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.08), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 255, 0.98));
}

.reservation-card-available {
  border-color: #d9ebd2;
  background:
    radial-gradient(circle at top right, rgba(74, 222, 128, 0.08), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 252, 248, 0.98));
}

.reservation-card-drone {
  border-color: #bfdbfe;
  background:
    radial-gradient(circle at top right, rgba(96, 165, 250, 0.08), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 250, 255, 0.98));
}

.reservation-card-reserved::before {
  content: none;
  display: none;
  background: none;
}

.reservation-card-available::before {
  content: none;
  display: none;
  background: none;
}

.reservation-card-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 12px;
  align-items: center;
}

.reservation-card-row > :first-child {
  min-width: 0;
}

.reservation-card-topline {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.reservation-tag {
  font-weight: 700;
  font-size: 15px;
  letter-spacing: -0.01em;
}

.reservation-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
}

.reservation-chip-reserved {
  background: #dbeafe;
  color: #1d4ed8;
}

.reservation-chip-available {
  background: #dcfce7;
  color: #166534;
}

.reservation-chip-drone {
  background: #dbeafe;
  color: #1d4ed8;
}

.reservation-card-text {
  margin-top: 4px;
  font-size: 12px;
  color: var(--muted);
  line-height: 1.5;
}

.reservation-card-meta {
  margin-top: 4px;
  font-size: 12px;
  font-weight: 600;
  color: var(--muted-strong);
  line-height: 1.45;
}

.reservation-inline-input-wrap {
  margin-top: 8px;
}

.reservation-inline-input {
  min-height: 36px;
  max-width: 360px;
}

.reservation-card-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  flex-shrink: 0;
  align-items: center;
}

.reservation-card-row > button {
  flex-shrink: 0;
  align-self: center;
  min-height: 40px;
}

.reservation-section .btn-primary,
.reservation-section .btn-secondary {
  min-height: 40px;
  padding: 0 16px;
  border-radius: 14px;
}

.reservation-section .btn-secondary {
  background: rgba(255, 255, 255, 0.86);
  border-color: rgba(203, 213, 225, 0.8);
}

.reservation-section-reserved .btn-secondary {
  border-color: rgba(191, 219, 254, 0.8);
}

.reservation-section-available .btn-secondary {
  border-color: rgba(187, 247, 208, 0.8);
}

.reservation-section-drone .btn-secondary {
  border-color: rgba(186, 230, 253, 0.85);
}

