@media (max-width: 1024px) {
  .app-main {
    margin-left: 0;
    padding: calc(var(--topbar-height) + 12px) 16px 16px;
  }

  .app-sidebar {
    top: 0;
    left: 0;
    bottom: 0;
    transform: translateX(-100%);
    width: 250px;
    box-shadow: var(--shadow-md);
  }

  .app-sidebar.open {
    transform: translateX(0);
  }

  .mobile-menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface-subtle);
    color: var(--muted-strong);
    cursor: pointer;
  }

  .top-fact-wrap {
    min-width: 0;
  }

  .app-topbar {
    top: 0;
    left: 0;
    right: 0;
    height: var(--topbar-height);
    padding: 10px 12px;
  }

  .topbar-left {
    min-width: 0;
  }

  .top-breadcrumb-link,
  .top-breadcrumb-current {
    max-width: 140px;
  }

  .avatar-text {
    display: none;
  }

  .theme-toggle-label {
    display: none;
  }

  .dashboard-row {
    grid-template-columns: 1fr;
  }

  .metric-item {
    border-right: none;
    border-bottom: 1px solid var(--border-subtle);
  }

  .metric-item:last-child {
    border-bottom: none;
  }

  .register-pill-tabs {
    display: flex;
    width: 100%;
  }

  .register-pill-tab {
    flex: 1 1 140px;
    min-width: 0;
  }

  .register-subtabs {
    display: flex;
    width: 100%;
  }

  .register-subtab {
    flex: 1 1 120px;
    min-width: 0;
  }

  .activity-feed-card {
    flex-direction: column;
    align-items: stretch;
  }

  .activity-feed-actions {
    justify-content: flex-start;
  }

  .activity-feed-action-btn {
    padding: 6px 9px;
  }

  .department-card {
    padding: 12px 14px;
  }

  .department-card-name {
    font-size: 13px;
  }

  .department-card-count {
    min-width: 34px;
    height: 34px;
    font-size: 16px;
    border-radius: 12px;
  }

}
